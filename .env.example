# Copy to .env and fill in. Used by docker-compose.yml.
PGUSER=openconcord
PGPASSWORD=change-me-to-a-long-random-secret

# Public subdomain for the Shiny app (point its DNS A record at this VPS).
APP_DOMAIN=concord.maxwellhowegis.com

# Only needed if you run the optional tile/feature API profile:
# API_DOMAIN=concord-api.maxwellhowegis.com
