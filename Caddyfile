# Caddy fronts the R Shiny app with TLS. Point APP_DOMAIN's DNS A record at this
# VPS first, e.g. concord.maxwellhowegis.com. Auto-provisions a Let's Encrypt cert.
{$APP_DOMAIN} {
	encode zstd gzip
	# Shiny needs WebSocket upgrades — Caddy's reverse_proxy handles them by default.
	reverse_proxy openconcord-shiny:3838
}

